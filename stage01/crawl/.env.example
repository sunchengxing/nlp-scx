# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=crawlee_data

# DBUtils Pool
DB_POOL_MIN=3
DB_POOL_MAX=10
DB_POOL_MAXUSAGE=1000
DB_IDLE_TIMEOUT=3600

# Crawlee
CRAWL_CONCURRENCY=10
CRAWL_RETRY_TIMES=3
CRAWL_REQUEST_DELAY=0.5

# Log
LOG_LEVEL=INFO
LOG_FILE=crawlee_data.log
