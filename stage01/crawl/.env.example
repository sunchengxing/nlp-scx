# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=crawlee_data

# DBUtils Pool
DB_POOL_MIN=3
DB_POOL_MAX=10
DB_POOL_MAXUSAGE=1000
DB_IDLE_TIMEOUT=3600

# Crawlee
CRAWL_CONCURRENCY=10
CRAWL_RETRY_TIMES=3
CRAWL_REQUEST_DELAY=0.5

# Log
LOG_LEVEL=INFO
LOG_FILE=crawlee_data.log

# ============================================================
# AKShare 东方财富配置
# ============================================================

# 东方财富 Cookie（AKShare 请求东财接口时携带）
AKSHARE_EM_COOKIE=

# AKShare 请求间隔（秒），防止被封
AKSHARE_REQUEST_INTERVAL=0.5

# ============================================================
# 远程服务器鉴权配置
# ============================================================

# 远程数据服务地址
REMOTE_SERVER_URL=http://localhost:8900

# 远程服务 Bearer Token
REMOTE_SERVER_TOKEN=
